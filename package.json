{
  "name": "x-account-cleaner",
  "version": "1.0.0",
  "description": "Open-source local-first X / Twitter account cleanup CLI built with Playwright: bulk delete tweets and replies, undo retweets, unlike tweets, remove bookmarks, and review/unfollow accounts safely.",
  "main": "dist/index.js",
  "bin": {
    "x-account-cleaner": "dist/index.js"
  },
  "files": [
    "dist/",
    "src/",
    "docs/",
    "examples/",
    "scripts/",
    "config.json",
    "selectors.json",
    "env.example",
    "install.sh",
    "install.bat",
    "start.sh",
    "start.bat",
    "QUICKSTART.md",
    "START_HERE.md",
    "llms.txt",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "选择器配置说明.md",
    "选择器快速参考.txt",
    "登录说明.md",
    "启动指南.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/tytsxai/x-account-cleaner#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tytsxai/x-account-cleaner.git"
  },
  "bugs": {
    "url": "https://github.com/tytsxai/x-account-cleaner/issues"
  },
  "scripts": {
    "start": "ts-node src/index.ts",
    "build": "tsc",
    "prestart:prod": "npm run build",
    "start:prod": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rimraf dist",
    "test:selectors": "node scripts/test-selectors.js",
    "test:following": "node scripts/test-following-management.js",
    "test:run-lock": "node scripts/test-run-lock.js",
    "test:config": "node scripts/test-config.js",
    "test:cli": "node scripts/test-cli.js",
    "prepack": "npm run build",
    "verify": "npm run build && npm run lint && npm run format:check && npm run test:cli && npm run test:selectors && npm run test:following && npm run test:run-lock && npm run test:config",
    "release:check": "npm run verify && npm pack --dry-run"
  },
  "keywords": [
    "twitter",
    "x",
    "x-cleaner",
    "x-account-cleaner",
    "x-account-cleanup",
    "twitter-cleaner",
    "twitter-auto-cleaner",
    "twitter-account-cleaner",
    "twitter-account-cleanup",
    "twitter-account-cleanup-tool",
    "x-account-cleanup-tool",
    "x-twitter-cleaner",
    "account-cleaner",
    "tweet-cleaner",
    "tweet-cleanup",
    "twitter-delete-tool",
    "tweet-delete",
    "delete-tweets",
    "bulk-delete-tweets",
    "bulk-delete-twitter",
    "bulk-delete-x",
    "delete-all-tweets",
    "mass-delete-tweets",
    "tweet-deleter",
    "bulk-unlike",
    "unlike-tweets",
    "delete-twitter-likes",
    "bulk-unfollow",
    "twitter-unfollow",
    "x-unfollow-tool",
    "remove-bookmarks",
    "bookmark-cleaner",
    "twitter-bookmark-cleaner",
    "social-media-cleanup",
    "twitter-privacy-tool",
    "privacy-tool",
    "local-first",
    "automation",
    "browser-automation",
    "cleaner",
    "playwright",
    "playwright-twitter",
    "typescript"
  ],
  "author": "tytsxai",
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.40.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "minimatch": "^3.1.5",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "overrides": {
    "ajv": "^6.14.0",
    "diff": "^4.0.4",
    "flatted": "^3.4.2",
    "glob": "^10.5.0",
    "js-yaml": "^4.1.1",
    "picomatch": "^2.3.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
